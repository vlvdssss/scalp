# ── Required: Telegram bot token from @BotFather ─────────────────────────────
BOT_TOKEN=

# ── Allowed Telegram user IDs (whitelist, comma-separated) ───────────────────
# Get your ID from @userinfobot in Telegram
ALLOWED_USER_IDS=123456789

# ── GitHub Pages URL (permanent, set once after first push) ──────────────────
# After push: https://YOUR_USERNAME.github.io/YOUR_REPO/
# Leave empty to serve webapp from the local FastAPI server instead
WEBAPP_URL=https://YOUR_USERNAME.github.io/YOUR_REPO/

# ── API_URL is set automatically by run_with_cloudflare.ps1 ──────────────────
# The cloudflare tunnel URL so the GitHub Pages webapp knows which API to call.
# Leave empty here — run_with_cloudflare.ps1 sets it automatically at startup.
API_URL=

# ── FastAPI backend listen address ────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8100

# ── REST API key (sent as X-API-Key header) ───────────────────────────────────
# Pick any random string — it protects the API from unauthorized access.
# Example: python -c "import secrets; print(secrets.token_hex(16))"
API_KEY=
